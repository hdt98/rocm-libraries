FROM ubuntu:24.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Set up working directory
ENV WORKDIR=/root/workdir
ENV ROCM_PATH=/opt/rocm
ENV ROCK_REPO_FOLDER_PATH=${WORKDIR}/therock
ENV ROCK_VENV_PATH=${WORKDIR}/rock-venv
ENV AMDGPU_FAMILIES=gfx94X-dcgpu

# Install required system packages
RUN apt-get update && apt-get install -y \ 
    python3 \
    python3-venv \
    python3-pip \
    git \
    curl \
    wget \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create working directory
RUN mkdir -p ${WORKDIR}
WORKDIR ${WORKDIR}

# Create Python 3.11 venv and install dependencies
RUN python3 -m venv ${ROCK_VENV_PATH}

# Clone TheROCk repository and checkout specific commit
RUN git clone https://github.com/ROCm/TheROCk.git ${ROCK_REPO_FOLDER_PATH} && \ 
    cd ${ROCK_REPO_FOLDER_PATH} 

# Install ROCk requirements in venv
RUN . ${ROCK_VENV_PATH}/bin/activate && \
    pip install -r ${ROCK_REPO_FOLDER_PATH}/requirements.txt

# Install pre-commit for code quality checks
RUN pip3 install --break-system-packages pre-commit

# Add ROCm bin to PATH
ENV PATH="${ROCM_PATH}/bin:${PATH}"
ENV HIP_DEVICE_LIB_PATH="${ROCM_PATH}/lib/llvm/amdgcn/bitcode"
ENV AMD_LOG_LEVEL=3
ENV HIP_PATH=${ROCM_PATH}
ENV LD_LIBRARY_PATH=${ROCM_PATH}/lib:${ROCM_PATH}/llvm/lib/clang/22/lib/linux:${LD_LIBRARY_PATH}
ENV LIBRARY_PATH=${ROCM_PATH}/lib:${LIBRARY_PATH}
ENV ROCM_DEVICE_LIB_PATH=${HIP_DEVICE_LIB_PATH}
ENV INC=${ROCM_PATH}/include
ENV CPLUS_INCLUDE_PATH=${INC}:${CPLUS_INCLUDE_PATH}
ENV CPATH=${INC}:${CPATH}
ENV CXXFLAGS="-isystem ${INC} ${CXXFLAGS}"
ENV CPPFLAGS="-isystem ${INC} ${CPPFLAGS}"
ENV AMD_LOG_LEVEL=3
ENV HSA_XNACK=1
ENV ASAN_OPTIONS=detect_odr_violation=0:quarantine_size_mb=600
ENV VENV_DIR=${ROCK_VENV_PATH}
ENV OUTPUT_ARTIFACTS_DIR=${ROCM_PATH}
ENV THEROCK_BIN_DIR=${ROCM_PATH}/bin
ENV AMDGPU_FAMILIES=gfx94X-dcgpu
ENV TEST_TYPE=smoke

# To reproduce the test failures:
# Launch a container of an image that is generated from this docker file, making sure GPU is passed to the container
# Activate ROCK venv
# cd into ROCk repo
# Execute tests (available in build_tools/github_actions/test_executable_scripts/)
# For e.g., here is a snippet for executing rocr tests
#   root@2b46fd527b4e:~/workdir# source ${ROCK_VENV_PATH}/bin/activate
#  (rock-venv) root@2b46fd527b4e:~/workdir# cd ${ROCK_REPO_FOLDER_PATH}
#       (rock-venv) root@2b46fd527b4e:~/workdir/therock# python build_tools/github_actions/test_executable_scripts/test_miopen.py

CMD ["/bin/bash"]