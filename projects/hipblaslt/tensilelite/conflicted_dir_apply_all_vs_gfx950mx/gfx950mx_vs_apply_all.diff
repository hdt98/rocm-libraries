diff --git a/projects/hipblaslt/tensilelite/rocisa/test/test_functions.py b/projects/hipblaslt/tensilelite/rocisa/test/test_functions.py
new file mode 100644
index 0000000000..c69e0d39b9
--- /dev/null
+++ b/projects/hipblaslt/tensilelite/rocisa/test/test_functions.py
@@ -0,0 +1,270 @@
+################################################################################
+#
