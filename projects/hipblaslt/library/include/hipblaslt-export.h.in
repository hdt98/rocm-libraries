/* Mirrors what `generate_export_header(hipblaslt)` would produce for the
 * library's default visibility settings (`CXX_VISIBILITY_PRESET=hidden`,
 * `VISIBILITY_INLINES_HIDDEN=ON`).
 *
 * Used in two places:
 *   - tensilelite-only builds (HIPBLASLT_ENABLE_HOST=OFF), where no
 *     `hipblaslt` target exists and `generate_export_header` cannot run.
 *   - via `configure_file(... COPYONLY)` in projects/hipblaslt/CMakeLists.txt.
 *
 * When HIPBLASLT_ENABLE_HOST=ON, `library/include/CMakeLists.txt` overwrites
 * this file via `generate_export_header(hipblaslt ...)` so the dynamically
 * derived attributes win in that build configuration.
 */
#ifndef HIPBLASLT_EXPORT_H
#define HIPBLASLT_EXPORT_H

#ifndef HIPBLASLT_EXPORT
#  define HIPBLASLT_EXPORT __attribute__((visibility("default")))
#endif

#ifndef HIPBLASLT_NO_EXPORT
#  define HIPBLASLT_NO_EXPORT __attribute__((visibility("hidden")))
#endif

#ifndef HIPBLASLT_DEPRECATED
#  define HIPBLASLT_DEPRECATED __attribute__((__deprecated__))
#endif

#ifndef HIPBLASLT_DEPRECATED_EXPORT
#  define HIPBLASLT_DEPRECATED_EXPORT HIPBLASLT_EXPORT HIPBLASLT_DEPRECATED
#endif

#ifndef HIPBLASLT_DEPRECATED_NO_EXPORT
#  define HIPBLASLT_DEPRECATED_NO_EXPORT HIPBLASLT_NO_EXPORT HIPBLASLT_DEPRECATED
#endif

#endif /* HIPBLASLT_EXPORT_H */
