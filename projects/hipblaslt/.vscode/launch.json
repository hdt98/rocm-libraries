{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "C/C++ Debug (gdb Launch)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/release-debug/clients/hipblaslt-bench",
            "args": [
                "--yaml",
                "debug_config.yaml",
                "--device",
                "7"
            ],
            "miDebuggerPath": "/opt/rocm/bin/rocgdb",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LD_PRELOAD",
                    "value": "${workspaceFolder}/build/release-debug/library/libhipblaslt.so"
                }
            ],
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set non-stop mode off",
                    "text": "set non-stop off",
                    "ignoreFailures": true
                }
            ]
        },
    ]
}