{% block includes %}
// Include utils for {{algo_name}}_config<...>.
#include "rocprim/device/detail/device_config_helper.hpp" 
// Include 'rocprim::empty_type'.
#include "rocprim/types.hpp" 
// Include main benchmarking logic {{algo_type}}_{{algo_name}}_benchmark.
#include "benchmark_{{algo_type}}_{{algo_name}}.hpp"
// Include primbench executor.
#include "primbench.hpp"
// Include fixed-width integers for interop with python.
#include <cstdint>
{% endblock %}

{% block extern_c_wrapper %}
extern "C" float {{algo_type}}_{{algo_name}}_wrapper(
    {% block arguments %}
    uint64_t bytes_size
    {% endblock %}
)
{
    // Flush is required for fancy primbench printing due to use
    // of terminal control characters.
    std::cout << std::flush;

    {% block config %}
    using config = rocprim::{{algo_name}}_config<{{config_params}}>;
    {% endblock %}

    {% block type_definitions %}
    using key_type = {{key_type}};
    {% if value_type %}
    using value_type = {{value_type}};
    {% else %}
    using value_type = rocprim::empty_type;
    {% endif %}
    {% endblock %}

    {% block benchmark_type %}
    using benchmark_type = {{algo_type}}_{{algo_name}}_benchmark<key_type, value_type, config>;
    {% endblock %}

    {% block benchmark_exec %}
    char* args[] = { "ignore-first-arg", /* You can pass arguments to primbench CLI here! */ };
    auto exec = primbench::executor(1, args, bytes_size, primbench::flags::none, 0);
    exec.queue<benchmark_type>();
    exec.run();
    return exec.get_last_bytes_per_second();
    {% endblock %}
}
{% endblock %}