void {{ op.class_name }}::finalize()
{
{% for tf in op.required_tensor_fields %}
    THROW_IF_NULL({{ tf.member_name }},
                  HIPDNN_STATUS_BAD_PARAM,
                  "{{ op.class_name }}::finalize() failed: {{ tf.attr_suffix }} tensor not set");
{% endfor %}
{% for df in op.required_data_fields %}
{% if df.is_vector %}
    THROW_IF_TRUE(_data.{{ df.fbs_field }}.empty(),
                  HIPDNN_STATUS_BAD_PARAM,
                  "{{ op.class_name }}::finalize() failed: {{ df.name }} not set");
{% endif %}
{% endfor %}
{% if op.has_compute_data_type %}
    THROW_IF_TRUE(_computeDataType == {{ op.fbs_namespace }}::DataType::UNSET,
                  HIPDNN_STATUS_BAD_PARAM,
                  "{{ op.class_name }}::finalize() failed: compute data type not "
                  "set");
{% endif %}
{% for ef in op.enum_fields %}
    THROW_IF_TRUE(_data.{{ ef.fbs_field }} == {{ ef.cpp_enum }}::UNSET,
                  HIPDNN_STATUS_BAD_PARAM,
                  "{{ op.class_name }}::finalize() failed: {{ ef.name }} not set");
{% endfor %}
{% for cf in op.mode_fields %}
    THROW_IF_TRUE(_data.{{ cf.fbs_field }} == {{ cf.cpp_enum }}::UNSET,
                  HIPDNN_STATUS_BAD_PARAM,
                  "{{ op.class_name }}::finalize() failed: {{ cf.name }} not set");
{% endfor %}

    HipdnnBackendDescriptorImpl<{{ op.class_name }}>::finalize();
}

// ============================================================================
// setAttribute
// ============================================================================

void {{ op.class_name }}::setAttribute(hipdnnBackendAttributeName_t attributeName,
                                                     hipdnnBackendAttributeType_t attributeType,
                                                     int64_t elementCount,
                                                     const void* arrayOfElements)
{
    THROW_IF_TRUE(isFinalized(),
                  HIPDNN_STATUS_NOT_INITIALIZED,
                  "{{ op.class_name }}::setAttribute() failed: Already finalized.");

    switch(attributeName)
    {
{% for tf in op.tensor_fields %}
    case {{ op.operation_attr_prefix }}_{{ tf.attr_suffix }}:
        setTensorDescriptor({{ tf.member_name }},
                            _data.{{ tf.uid_field }},
                            attributeType,
                            elementCount,
                            arrayOfElements,
                            "{{ op.class_name }}::setAttribute()");
        break;
{% endfor %}
{% for df in op.data_fields %}
{% if df.is_vector %}
    case {{ df.attr_name }}:
        setInt64Vector(_data.{{ df.fbs_field }},
                       attributeType,
                       elementCount,
                       arrayOfElements,
                       "{{ op.class_name }}::setAttribute()");
        break;
{% elif df.is_mode %}
    case {{ df.attr_name }}:
        {{ df.backend_setter }}(_data.{{ df.fbs_field }},
                    attributeType,
                    elementCount,
                    arrayOfElements,
                    "{{ op.class_name }}::setAttribute()");
        break;
{% elif df.is_enum %}
    case {{ df.attr_name }}:
        {{ df.setter_helper_name }}(attributeType, elementCount, arrayOfElements);
        break;
{% elif df.is_scalar %}
    case {{ df.attr_name }}:
        setScalar(_data.{{ df.fbs_field }},
                  {{ df.backend_type }},
                  attributeType,
                  elementCount,
                  arrayOfElements,
                  "{{ op.class_name }}::setAttribute()");
        break;
{% endif %}
{% endfor %}
{% if op.has_compute_data_type %}
    case {{ op.compute_data_type_attr }}:
        setDataType(_computeDataType,
                    attributeType,
                    elementCount,
                    arrayOfElements,
                    "{{ op.class_name }}::setAttribute()");
        break;
{% endif %}
{% for taf in op.tensor_array_fields %}
    case {{ taf.attr_name }}:
        setTensorArrayDesc(attributeName, attributeType, elementCount, arrayOfElements);
        break;
{% endfor %}
    case HIPDNN_ATTR_OPERATION_NAME_EXT:
        setString(_name,
                  attributeType,
                  elementCount,
                  arrayOfElements,
                  "{{ op.class_name }}::setAttribute()");
        break;
    default:
        throw HipdnnException(HIPDNN_STATUS_NOT_SUPPORTED,
                              "{{ op.class_name }}::setAttribute: attributeName not "
                              "supported");
    }
}
{% for ef in op.enum_fields %}

void {{ op.class_name }}::{{ ef.setter_helper_name }}(hipdnnBackendAttributeType_t attributeType,
                                                    int64_t elementCount,
                                                    const void* arrayOfElements)
{
    checkSetArgs(HIPDNN_TYPE_INT64,
                 attributeType,
                 arrayOfElements,
                 "{{ op.class_name }}::setAttribute()");
    THROW_IF_FALSE(elementCount == 1,
                   HIPDNN_STATUS_BAD_PARAM,
                   "{{ op.class_name }}::setAttribute(): elementCount is not 1");
    auto mode = static_cast<{{ ef.cpp_enum }}>(
        *static_cast<const int64_t*>(arrayOfElements));
    THROW_IF_TRUE(mode < {{ ef.cpp_enum }}::MIN
                      || mode > {{ ef.cpp_enum }}::MAX,
                  HIPDNN_STATUS_BAD_PARAM,
                  "{{ op.class_name }}::setAttribute(): invalid {{ ef.enum_short_type }} value");
    _data.{{ ef.fbs_field }} = mode;
}
{% endfor %}
{% if op.has_tensor_array_fields %}

void {{ op.class_name }}::setTensorArrayDesc(hipdnnBackendAttributeName_t attributeName,
                                                            hipdnnBackendAttributeType_t attributeType,
                                                            int64_t elementCount,
                                                            const void* arrayOfElements)
{
    THROW_IF_NULL(arrayOfElements,
                  HIPDNN_STATUS_BAD_PARAM_NULL_POINTER,
                  "{{ op.class_name }}::setAttribute(): arrayOfElements is null");
    THROW_IF_FALSE(attributeType == HIPDNN_TYPE_BACKEND_DESCRIPTOR,
                   HIPDNN_STATUS_BAD_PARAM,
                   "{{ op.class_name }}::setAttribute(): attributeType is not "
                   "BACKEND_DESCRIPTOR");
    THROW_IF_FALSE(elementCount >= 1,
                   HIPDNN_STATUS_BAD_PARAM,
                   "{{ op.class_name }}::setAttribute(): elementCount < 1");

    auto descs = static_cast<HipdnnBackendDescriptor* const*>(arrayOfElements);
    std::vector<std::shared_ptr<TensorDescriptor>> tensorDescs;
    std::vector<int64_t> uids;

    for(int64_t i = 0; i < elementCount; ++i)
    {
        auto tensorDesc = HipdnnBackendDescriptor::unpackDescriptor<TensorDescriptor>(
            &descs[i],
            HIPDNN_STATUS_BAD_PARAM,
            "{{ op.class_name }}::setAttribute(): Failed to unpack tensor "
            "descriptor");
        THROW_IF_FALSE(tensorDesc->isFinalized(),
                       HIPDNN_STATUS_BAD_PARAM_NOT_FINALIZED,
                       "{{ op.class_name }}::setAttribute(): Tensor descriptor "
                       "not finalized");
        tensorDescs.push_back(tensorDesc);
        uids.push_back(tensorDesc->getData().uid);
    }

{% for taf in op.tensor_array_fields %}
{% if not loop.first %}
    else {% endif %}{% if loop.first %}    {% endif %}if(attributeName == {{ taf.attr_name }})
    {
        _{{ taf.name }}Descs = std::move(tensorDescs);
        _data.{{ taf.fbs_field }} = std::move(uids);
    }
{% endfor %}
    else
    {
        throw HipdnnException(HIPDNN_STATUS_BAD_PARAM,
                              "{{ op.class_name }}::setTensorArrayDesc(): unsupported "
                              "attribute name");
    }
}
{% endif %}

