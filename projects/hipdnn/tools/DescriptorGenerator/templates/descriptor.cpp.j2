std::vector<std::shared_ptr<TensorDescriptor>>
    {{ op.class_name }}::getTensorDescriptors() const
{
{% if op.has_tensor_array_fields %}
    std::vector<std::shared_ptr<TensorDescriptor>> result = {{ '{' }}{% for tf in op.tensor_fields %}{{ tf.member_name }}{% if not loop.last %}, {% endif %}{% endfor %}{{ '}' }};
{% for taf in op.tensor_array_fields %}
    result.insert(result.end(), _{{ taf.name }}Descs.begin(), _{{ taf.name }}Descs.end());
{% endfor %}
    return result;
{% else %}
    return {{ '{' }}{% for tf in op.tensor_fields %}{{ tf.member_name }}{% if not loop.last %}, {% endif %}{% endfor %}{{ '}' }};
{% endif %}
}

std::unique_ptr<{{ op.fbs_namespace }}::NodeT>
    {{ op.class_name }}::buildNode() const
{
    auto node = std::make_unique<{{ op.fbs_namespace }}::NodeT>();
    node->name = _name;
{% if op.has_compute_data_type %}
    node->compute_data_type = _computeDataType;
{% endif %}
    node->attributes.Set({{ op.fbs_namespace }}::{{ op.fbs_t_type }}(_data));
    return node;
}

hipdnnBackendDescriptorType_t {{ op.class_name }}::getStaticType()
{
    return {{ op.descriptor_type_enum }};
}

std::string {{ op.class_name }}::toString() const
{
    using hipdnn_data_sdk::utilities::vecToString;
    std::string str = "{{ op.class_name }}: {";
    str += "name=" + _name;
{% for tf in op.tensor_fields %}
    str += ", {{ tf.name }}_uid=" + std::to_string(_data.{{ tf.uid_field }});
{% endfor %}
{% for df in op.data_fields %}
{% if df.is_vector %}
    str += ", {{ df.name }}=" + vecToString(_data.{{ df.fbs_field }});
{% elif df.is_mode %}
    str += ", {{ df.name }}=" + std::to_string(static_cast<int>(_data.{{ df.fbs_field }}));
{% elif df.is_enum %}
    str += ", {{ df.name }}=" + std::to_string(static_cast<int>(_data.{{ df.fbs_field }}));
{% elif df.is_scalar %}
    str += ", {{ df.name }}=" + std::to_string(_data.{{ df.fbs_field }});
{% endif %}
{% endfor %}
{% for taf in op.tensor_array_fields %}
    str += ", {{ taf.name }}_uids=" + vecToString(_data.{{ taf.fbs_field }});
{% endfor %}
{% if op.has_compute_data_type %}
    str += ", compute_data_type=";
    str += {{ op.fbs_namespace }}::EnumNameDataType(_computeDataType);
{% endif %}
    str += "}";
    return str;
}

std::shared_ptr<{{ op.class_name }}> {{ op.class_name }}::fromNode(
    const {{ op.fbs_namespace }}::NodeT& nodeT,
    const std::unordered_map<int64_t, std::shared_ptr<TensorDescriptor>>& tensorMap)
{
    const auto* attrs = nodeT.attributes.As{{ op.fbs_table }}();
    THROW_IF_NULL(attrs, HIPDNN_STATUS_INTERNAL_ERROR,
                  "{{ op.class_name }}::fromNode: {{ op.fbs_table }} is null");

    auto desc = std::make_shared<{{ op.class_name }}>();
    desc->_data = *attrs;
{% if op.has_compute_data_type %}
    desc->_computeDataType = nodeT.compute_data_type;
{% endif %}
    desc->_name = nodeT.name;
{% for tf in op.tensor_fields %}
{% if tf.required %}
    desc->{{ tf.member_name }} = findTensorInMap(
        tensorMap, attrs->{{ tf.uid_field }}, "{{ op.class_name }}::fromNode: {{ tf.pascal_name }}");
{% else %}
    if(attrs->{{ tf.uid_field }})
    {
        desc->{{ tf.member_name }} = findTensorInMap(
            tensorMap, attrs->{{ tf.uid_field }}, "{{ op.class_name }}::fromNode: {{ tf.pascal_name }}");
    }
{% endif %}
{% endfor %}
{% for taf in op.tensor_array_fields %}
    for(auto uid : attrs->{{ taf.fbs_field }})
    {
        desc->_{{ taf.name }}Descs.push_back(
            findTensorInMap(tensorMap, uid, "{{ op.class_name }}::fromNode: {{ taf.name }}"));
    }
{% endfor %}
    desc->finalize();
    return desc;
}

} // namespace hipdnn_backend
