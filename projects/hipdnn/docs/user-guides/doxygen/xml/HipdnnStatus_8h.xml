          </detaileddescription>
        </enumvalue>
        <enumvalue id="HipdnnStatus_8h_1aea82d15fc8702bfe60f61f219d150345a0f83bb5f28443736387d6ec08996d909" prot="public">
          <name>HIPDNN_STATUS_INTERNAL_ERROR_DEVICE_ALLOCATION_FAILED</name>
          <initializer>= 12</initializer>
          <briefdescription>
<para>Device memory allocation failed. </para>
          </briefdescription>
          <detaileddescription>
