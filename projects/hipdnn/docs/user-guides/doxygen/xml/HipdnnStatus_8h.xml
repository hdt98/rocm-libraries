          <initializer>= 13</initializer>
          <briefdescription>
<para>GPU kernel execution failed. </para>
          </briefdescription>
          <detaileddescription>
<para>The GPU program failed to execute. This could indicate invalid tensor data, incorrect dimensions, or a GPU error. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="HipdnnStatus_8h_1aea82d15fc8702bfe60f61f219d150345ae99f6e004b5ff402170ed11bb6e17125" prot="public">
