          <initializer>= 9</initializer>
          <briefdescription>
<para>Internal library error (category) </para>
          </briefdescription>
          <detaileddescription>
<para>An internal hipDNN operation failed. This typically indicates a bug in the library. </para>
          </detaileddescription>
        </enumvalue>
