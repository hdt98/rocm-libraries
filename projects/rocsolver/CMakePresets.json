{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 13,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Release Build",
      "description": "Configure for release build with installation to /opt/rocm",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "/opt/rocm/bin/amdclang++",
        "CMAKE_C_COMPILER": "/opt/rocm/bin/amdclang",
        "CMAKE_Fortran_COMPILER": "gfortran",
        "CMAKE_PREFIX_PATH": "/opt/rocm",
        "CMAKE_INSTALL_PREFIX": "/opt/rocm"
      },
      "environment": {
        "ROCM_PATH": "/opt/rocm"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Build",
      "description": "Configure for debug build with all clients enabled",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_CLIENTS_TESTS": "ON",
        "BUILD_CLIENTS_BENCHMARKS": "ON",
        "BUILD_CLIENTS_SAMPLES": "ON"
      }
    },
    {
      "name": "clients-only",
      "displayName": "Clients Development",
      "description": "Configure for clients-only build (library not built)",
      "inherits": "debug",
      "cacheVariables": {
        "BUILD_LIBRARY": "OFF"
      }
    },
    {
      "name": "coverage",
      "displayName": "Code Coverage",
      "description": "Configure for code coverage analysis",
      "inherits": "debug",
      "cacheVariables": {
        "BUILD_CODE_COVERAGE": "ON"
      }
    },
    {
      "name": "asan",
      "displayName": "Address Sanitizer",
      "description": "Configure with address sanitizer enabled",
      "inherits": "debug",
      "cacheVariables": {
        "BUILD_ADDRESS_SANITIZER": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "displayName": "Build Default",
      "description": "Build using default configuration"
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Build Debug",
      "description": "Build using debug configuration"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "debug",
      "displayName": "Test Default",
      "description": "Run all tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
