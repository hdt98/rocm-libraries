// clang-format off

#include "benchmark_cshuffle_lds.hpp"
#include "ck_tile/host/kernel_launch.hpp"
#include <iostream>
#include <cstdlib>
#include <cstring>
#include <fstream>
#include <chrono>

using Epilogue = ck_tile::BenchmarkEpilogue<
    @A_TYPE@, @B_TYPE@, @ACC_TYPE@, @O_TYPE@,
    @M@, @N@, @M_WAVE@, @N_WAVE@, @M_XDL@, @N_XDL@, @K_XDL@>;

using StoreSetup = ck_tile::LdsStoreSetup<Epilogue>;
using LoadSetup = ck_tile::LdsLoadSetup<Epilogue>;

void print_help(const char* prog)
{
    std::cout << "Usage: " << prog << " [options]\n"
              << "\n"
              << "LDS microbenchmark for CShuffleEpilogue (@CONFIG_NAME@)\n"
              << "\n"
              << "Options:\n"
              << "  -w, --warmup <N>   Warmup iterations (default: 3)\n"
              << "  -i, --iters <N>    Benchmark iterations (default: 10)\n"
              << "  -h, --help         Show this help message\n"
              << "\n"
              << "Configuration:\n"
              << "  MFMA tile:   @M_XDL@x@N_XDL@x@K_XDL@\n"
              << "  Wave layout: @M_WAVE@x@N_WAVE@\n"
              << "  Block tile:  @M@x@N@\n"
              << std::endl;
}

int main(int argc, char** argv)
{
    int warmup = 3;
    int iters  = 10;

    for (int i = 1; i < argc; ++i)
    {
        if (std::strcmp(argv[i], "-h") == 0 || std::strcmp(argv[i], "--help") == 0)
        {
            print_help(argv[0]);
            return 0;
        }
        else if ((std::strcmp(argv[i], "-w") == 0 || std::strcmp(argv[i], "--warmup") == 0) && i + 1 < argc)
        {
            warmup = std::atoi(argv[++i]);
        }
        else if ((std::strcmp(argv[i], "-i") == 0 || std::strcmp(argv[i], "--iters") == 0) && i + 1 < argc)
        {
            iters = std::atoi(argv[++i]);
        }
        else
        {
            std::cerr << "Unknown option: " << argv[i] << "\n";
            print_help(argv[0]);
            return 1;
        }
    }

    std::cout << "=== @CONFIG_NAME@ ===" << std::endl;

    // #region agent log
    {
        std::ofstream log(
            "/home/AMD/mpodkory/cursor_projects/rocm-libraries/projects/composablekernel/.cursor/debug-344d72.log",
            std::ios::app);
        if(log)
        {
            const auto ts = std::chrono::duration_cast<std::chrono::milliseconds>(
                                std::chrono::system_clock::now().time_since_epoch())
                                .count();
            log << "{\"sessionId\":\"344d72\",\"runId\":\"pre-fix\",\"hypothesisId\":\"H1\","
                << "\"location\":\"benchmark_template.cpp:main\","
                << "\"message\":\"Capture benchmark/store-load shape and vector width\","
                << "\"data\":{\"config\":\"@CONFIG_NAME@\",\"kBlockSize\":" << StoreSetup::kBlockSize
                << ",\"kBytes\":" << StoreSetup::kBytes
                << ",\"MPerIterationShuffle\":" << Epilogue::MPerIterationShuffle
                << ",\"NPerIterationShuffle\":" << Epilogue::NPerIterationShuffle
                << ",\"GetVectorSizeC\":" << Epilogue::GetVectorSizeC() << "},\"timestamp\":" << ts
                << "}\n";
            log << "{\"sessionId\":\"344d72\",\"runId\":\"pre-fix\",\"hypothesisId\":\"H2\","
                << "\"location\":\"benchmark_template.cpp:main\","
                << "\"message\":\"Descriptor stride likely maps lane-varying accesses to same bank group during store phases\","
                << "\"data\":{\"target\":\"store\"},\"timestamp\":" << ts << "}\n";
            log << "{\"sessionId\":\"344d72\",\"runId\":\"pre-fix\",\"hypothesisId\":\"H3\","
                << "\"location\":\"benchmark_template.cpp:main\","
                << "\"message\":\"Load path uses thread_raked read distribution and may naturally avoid conflicts\","
                << "\"data\":{\"target\":\"load\"},\"timestamp\":" << ts << "}\n";
            log << "{\"sessionId\":\"344d72\",\"runId\":\"pre-fix\",\"hypothesisId\":\"H4\","
                << "\"location\":\"benchmark_template.cpp:main\","
                << "\"message\":\"Conflicts may be specific to gfx950 bank phase behavior with ds_write_b128\","
                << "\"data\":{\"arch_hint\":\"gfx950\"},\"timestamp\":" << ts << "}\n";
        }
    }
    // #endregion

    ck_tile::stream_config stream{nullptr, true, 0, warmup, iters, true};

    // Store benchmark
    {
        float ms = ck_tile::launch_kernel(stream,
            ck_tile::make_kernel(ck_tile::StoreTile<StoreSetup>{},
                                 dim3(1), dim3(StoreSetup::kBlockSize), 0));
        double gb_s = (double(StoreSetup::kBytes) / 1e9) / (ms / 1e3);
        std::cout << "Store: " << ms << " ms, " << gb_s << " GB/s" << std::endl;
    }

    // Load benchmark
    {
        float ms = ck_tile::launch_kernel(stream,
            ck_tile::make_kernel(ck_tile::LoadTile<LoadSetup>{},
                                 dim3(1), dim3(LoadSetup::kBlockSize), 0));
        double gb_s = (double(LoadSetup::kBytes) / 1e9) / (ms / 1e3);
        std::cout << "Load:  " << ms << " ms, " << gb_s << " GB/s" << std::endl;
    }

    return 0;
}
