
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(hip REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/formocast-targets.cmake")

block(SCOPE_FOR VARIABLES)
    if(NOT TARGET formocast::formocast)
        message(FATAL_ERROR "formocast::formocast target is missing")
    endif()
    
    get_target_property(link_libraries formocast::formocast INTERFACE_LINK_LIBRARIES)

    if(link_libraries AND "hip::device" IN_LIST link_libraries)
        message(FATAL_ERROR "Do not export targets with hip::device as an interface link library")
    endif()
endblock()

