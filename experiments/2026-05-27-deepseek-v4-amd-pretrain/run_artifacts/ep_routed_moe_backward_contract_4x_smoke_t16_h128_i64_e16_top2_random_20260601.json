  "contract": {
    "forward_source": "MORI dispatch -> local AITER fused_moe -> MORI combine can be used for forward once wrapped",
    "backward_target": "combine backward produces route-output grads and top-k weight grads; expert backward aggregates local-owner dW across all ranks; dispatch backward returns accumulated dX to original token order",
    "reference_a": "full global TorchTitan-style routed SwiGLU autograd on each rank, then all-reduced dW",
    "reference_b": "route-decomposed VJP with scatter-add dX/dTopkWeight and all-reduced expert dW owner slices",
    "production_note": "No MORI or AITER kernels are used here; this defines the exact VJP semantics the training-safe MORI+AITER custom autograd path must match."
  },
