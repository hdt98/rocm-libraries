# Source repos are tracked snapshots at repo root. Keep source files reviewable;
# transient source-tree cache ignores live in the repo-root .gitignore.

# Raw outputs stay outside the repo record.
/run_artifacts/artifacts/
/run_artifacts/logs/
/run_artifacts/checkpoints/
run_artifacts/**
!run_artifacts/
run_artifacts/*.jsonl
run_artifacts/*.log
run_artifacts/*.txt
run_artifacts/*.pt
run_artifacts/*.pth
run_artifacts/*.ckpt
run_artifacts/*.safetensors
run_artifacts/profile_*
run_artifacts/structured_logs*
run_artifacts/remote_logs*
!run_artifacts/*.json
__pycache__/
.pytest_cache/
.DS_Store
*.pyc
