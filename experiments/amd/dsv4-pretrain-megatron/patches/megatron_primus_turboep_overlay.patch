diff --git a/megatron/training/training.py b/megatron/training/training.py
--- a/megatron/training/training.py
+++ b/megatron/training/training.py
@@ -216,6 +216,48 @@ def print_datetime(string, override_timestamp=None):
         time_str = datetime.fromtimestamp(override_timestamp).strftime('%Y-%m-%d %H:%M:%S.%f')
     print_rank_0(f'[{string}] datetime: {time_str} ')

+
+_DSV4_PRIMUS_TURBOEP_PATCHED = False
+
+
+def maybe_patch_dsv4_primus_turboep(args):
+    """Apply the Primus Turbo DeepEP dispatcher patch for explicit DSV4 runs."""
+    global _DSV4_PRIMUS_TURBOEP_PATCHED
+
+    if _DSV4_PRIMUS_TURBOEP_PATCHED:
+        return
+    if not getattr(args, 'use_turbo_deepep', False):
+        return
+    if getattr(args, 'tensor_model_parallel_size', 1) != 1:
+        raise RuntimeError('Primus Turbo DeepEP requires tensor_model_parallel_size == 1')
+
+    import importlib.util
+
+    if importlib.util.find_spec('primus_turbo') is None:
+        raise RuntimeError(
+            'Primus Turbo DeepEP requested, but primus_turbo is not importable. '
+            'Use a Primus image/runtime that provides primus_turbo.'
+        )
+
+    from megatron.core.transformer.moe import moe_layer, token_dispatcher
+    from primus.backends.megatron.core.extensions.primus_turbo import (
+        PrimusTurboDeepEPTokenDispatcher,
+    )
+
+    args.moe_enable_deepep = True
+    args.moe_token_dispatcher_type = 'flex'
+    args.moe_flex_dispatcher_backend = 'deepep'
+    if not hasattr(args, 'moe_router_force_load_balancing'):
+        args.moe_router_force_load_balancing = False
+    token_dispatcher.MoEFlexTokenDispatcher = PrimusTurboDeepEPTokenDispatcher
+    moe_layer.MoEFlexTokenDispatcher = PrimusTurboDeepEPTokenDispatcher
+    _DSV4_PRIMUS_TURBOEP_PATCHED = True
+    print_rank_0(
+        'DSV4 Primus TurboEP DeepEP dispatcher enabled: patched MoEFlexTokenDispatcher '
+        f'-> {PrimusTurboDeepEPTokenDispatcher.__name__}'
+    )
+
+
 def num_floating_point_operations(args, batch_size):
