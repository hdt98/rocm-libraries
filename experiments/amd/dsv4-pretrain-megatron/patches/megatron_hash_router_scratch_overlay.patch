 from megatron.core.transformer.transformer_config import TransformerConfig


+def _build_dsv4_scratch_tid2eid(vocab_size: int, num_experts: int, topk: int) -> torch.Tensor:
+    """Build deterministic hash routing for scratch DSV4 pretraining.
+
+    Checkpointed DSV4 models carry ``tid2eid`` weights. Pretraining from
+    scratch needs a valid table before any checkpoint exists, otherwise
+    hash-routed layers start with all ``-1`` expert ids.
+    """
+    assert vocab_size > 0
+    assert 0 < topk <= num_experts
+
+    token_ids = torch.arange(vocab_size, dtype=torch.int64).unsqueeze(1)
+    slots = torch.arange(topk, dtype=torch.int64).unsqueeze(0)
+    base = (token_ids * 1103515245 + 12345) % num_experts
+
+    if num_experts & (num_experts - 1) == 0:
+        stride = ((token_ids * 214013 + 2531011) % (num_experts // 2)) * 2 + 1
+    else:
+        stride = torch.ones_like(base)
+
+    return ((base + slots * stride) % num_experts).to(torch.int32)
+
+
 class Router(ABC, MegatronModule):
     """Base Router class"""

