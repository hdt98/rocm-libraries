+def _batched_indexer_fwd_torch(q, k, weights, cu_seqlen_ks, cu_seqlen_ke):
+    """Chunked PyTorch reference for V4 Lightning indexer logits."""
+    seqlen, batch, heads, dim = q.shape
+    seq_len_kv = k.shape[0]
+    chunk = int(os.environ.get("MILES_DSV4_INDEXER_REF_CHUNK", "128"))
+    kv_pos = torch.arange(seq_len_kv, device=q.device).view(1, seq_len_kv)
+    all_logits = torch.empty([batch, seqlen, seq_len_kv], device=q.device, dtype=torch.float32)
+
+    with torch.no_grad():
+        for b in range(batch):
+            kb = k[:, b, :].float()
+            for start in range(0, seqlen, chunk):
+                end = min(start + chunk, seqlen)
+                q_chunk = q[start:end, b, :, :].float()
+                w_chunk = weights[start:end, b, :].float()
+                scores = torch.einsum("qhd,kd->qhk", q_chunk, kb)
+                scores = torch.relu(scores) * w_chunk.unsqueeze(-1)
+                logits = scores.sum(dim=1)
+
+                cu_s = cu_seqlen_ks[start:end].long().view(end - start, 1)
+                cu_e = cu_seqlen_ke[start:end].long().view(end - start, 1)
+                valid = (kv_pos >= cu_s) & (kv_pos < cu_e)
+                all_logits[b, start:end] = logits.masked_fill(~valid, float("-inf"))
+
+    return all_logits
+

