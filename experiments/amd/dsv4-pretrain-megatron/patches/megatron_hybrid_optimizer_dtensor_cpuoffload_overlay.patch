 from collections import defaultdict
 from typing import Dict

 import torch

+try:
+    from torch.distributed.tensor import DTensor
+except ImportError:
+    DTensor = None
+
+
+def _is_dtensor(tensor):
+    return DTensor is not None and isinstance(tensor, DTensor)
+
+
+def _local_tensor(tensor):
+    if _is_dtensor(tensor):
+        return tensor.to_local()
+    return tensor
+
+
+def _copy_tensor_data_(dst, src, non_blocking=True):
+    dst_local = _local_tensor(dst)
+    src_local = _local_tensor(src)
+    src_local = src_local.to(device=dst_local.device, dtype=dst_local.dtype)
+    dst_local.data.copy_(src_local.data, non_blocking=non_blocking)
+    return dst
+

