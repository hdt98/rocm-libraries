diff --git a/megatron/core/transformer/transformer_layer.py b/megatron/core/transformer/transformer_layer.py
index 5c40d9fe73..a0a5cf5067 100644
--- a/megatron/core/transformer/transformer_layer.py
+++ b/megatron/core/transformer/transformer_layer.py
@@ -405,6 +405,21 @@ class BaseTransformerLayer(GraphableMegatronModule, ABC):
             self.hc_ffn_fn = torch.nn.Parameter(torch.empty(mix_size, hc_dim, dtype=torch.float32))
             self.hc_ffn_base = torch.nn.Parameter(torch.empty(mix_size, dtype=torch.float32))
             self.hc_ffn_scale = torch.nn.Parameter(torch.empty(3, dtype=torch.float32))
+            if self.config.perform_initialization:
+                # DSV4 checkpoints carry these tensors. Scratch pretraining must
+                # initialize them explicitly because torch.empty can otherwise feed
+                # arbitrary values into the MHC pre/post mixers.
+                pre_target = max(
+                    min(1.0 / hc_mult - self.config.dsv4_hc_eps, 1.0 - 1e-6),
+                    1e-6,
+                )
+                pre_base = float(torch.logit(torch.tensor(pre_target, dtype=torch.float32)).item())
+                with torch.no_grad():
+                    for p in [self.hc_attn_fn, self.hc_ffn_fn, self.hc_attn_scale, self.hc_ffn_scale]:
+                        p.zero_()
+                    for p in [self.hc_attn_base, self.hc_ffn_base]:
+                        p.zero_()
+                        p[:hc_mult].fill_(pre_base)
             for p in [self.hc_attn_fn, self.hc_attn_base, self.hc_attn_scale,
                        self.hc_ffn_fn, self.hc_ffn_base, self.hc_ffn_scale]:
                 p._keep_fp32 = True
